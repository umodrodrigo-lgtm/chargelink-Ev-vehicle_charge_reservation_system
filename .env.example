# ── Database ──────────────────────────────────────────────────────────────────
DB_USERNAME=chargelink
DB_PASSWORD=change_me_strong_db_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_strong_redis_password

# ── JWT ── generate with: openssl rand -base64 64 ─────────────────────────────
JWT_SECRET=change_me_run_openssl_rand_base64_64

# ── CORS ── your EC2 public IP or domain ─────────────────────────────────────
# Examples:
#   CORS_ORIGINS=http://54.123.45.67
#   CORS_ORIGINS=http://chargelink.example.com
CORS_ORIGINS=http://YOUR_EC2_PUBLIC_IP
