<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="ChargeLink — Performance Test">
      <boolProp name="TestPlan.serialize_threadgroups">false</boolProp>
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments" testname="User Defined Variables">
        <collectionProp name="Arguments.arguments">

          <elementProp name="BASE_URL" elementType="Argument">
            <stringProp name="Argument.name">BASE_URL</stringProp>
            <stringProp name="Argument.value">chargelink.limalshaumod.online</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>

          <!-- ── Change these to control the test ─────────────────────────── -->
          <elementProp name="THREADS" elementType="Argument">
            <stringProp name="Argument.name">THREADS</stringProp>
            <stringProp name="Argument.value">20</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>

          <elementProp name="RAMP_UP" elementType="Argument">
            <stringProp name="Argument.name">RAMP_UP</stringProp>
            <stringProp name="Argument.value">60</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>

          <elementProp name="DURATION" elementType="Argument">
            <stringProp name="Argument.name">DURATION</stringProp>
            <stringProp name="Argument.value">300</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <!-- ─────────────────────────────────────────────────────────────── -->

        </collectionProp>
      </elementProp>
    </TestPlan>
    <hashTree>

      <!-- ════════════════════════════════════════════════════════════════════
           Thread Group — duration-based scheduler, runs until DURATION expires
           ════════════════════════════════════════════════════════════════════ -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Concurrent Users">
        <intProp name="ThreadGroup.num_threads">${THREADS}</intProp>
        <intProp name="ThreadGroup.ramp_time">${RAMP_UP}</intProp>
        <boolProp name="ThreadGroup.scheduler">true</boolProp>
        <stringProp name="ThreadGroup.duration">${DURATION}</stringProp>
        <stringProp name="ThreadGroup.delay">0</stringProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">false</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller">
          <boolProp name="LoopController.continue_forever">true</boolProp>
          <intProp name="LoopController.loops">-1</intProp>
        </elementProp>
      </ThreadGroup>
      <hashTree>

        <!-- ── CSV Data Set — thread-safe user credentials ────────────────── -->
        <CSVDataSet guiclass="TestBeanGUI" testclass="CSVDataSet" testname="User Credentials">
          <stringProp name="filename">users.csv</stringProp>
          <stringProp name="variableNames">firstName,lastName,email,phone,password</stringProp>
          <boolProp name="ignoreFirstLine">true</boolProp>
          <stringProp name="delimiter">,</stringProp>
          <boolProp name="quotedData">false</boolProp>
          <boolProp name="recycle">true</boolProp>
          <boolProp name="stopThread">false</boolProp>
          <stringProp name="shareMode">shareMode.all</stringProp>
        </CSVDataSet>
        <hashTree/>

        <!-- ── HTTP Defaults ───────────────────────────────────────────────── -->
        <ConfigTestElement guiclass="HttpDefaultsGui" testclass="ConfigTestElement" testname="HTTP Request Defaults">
          <stringProp name="HTTPSampler.domain">${BASE_URL}</stringProp>
          <stringProp name="HTTPSampler.port">443</stringProp>
          <stringProp name="HTTPSampler.protocol">https</stringProp>
          <stringProp name="HTTPSampler.contentEncoding">UTF-8</stringProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="User Defined Variables">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
        </ConfigTestElement>
        <hashTree/>

        <!-- ── Global headers ─────────────────────────────────────────────── -->
        <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="Headers">
          <collectionProp name="HeaderManager.headers">
            <elementProp name="" elementType="Header">
              <stringProp name="Header.name">Content-Type</stringProp>
              <stringProp name="Header.value">application/json</stringProp>
            </elementProp>
            <elementProp name="" elementType="Header">
              <stringProp name="Header.name">Accept</stringProp>
              <stringProp name="Header.value">application/json</stringProp>
            </elementProp>
          </collectionProp>
        </HeaderManager>
        <hashTree/>

        <!-- ── Think time: 1–3 s between every request ────────────────────── -->
        <UniformRandomTimer guiclass="UniformRandomTimerGui" testclass="UniformRandomTimer" testname="Think Time 1-3s">
          <stringProp name="ConstantTimer.delay">1000</stringProp>
          <stringProp name="RandomTimer.range">2000</stringProp>
        </UniformRandomTimer>
        <hashTree/>

        <!-- ── SLA: each response must arrive within 3 s ──────────────────── -->
        <DurationAssertion guiclass="DurationAssertionGui" testclass="DurationAssertion" testname="SLA — Response under 3s">
          <stringProp name="DurationAssertion.duration">3000</stringProp>
        </DurationAssertion>
        <hashTree/>

        <!-- ══════════════════════════════════════════════════════════════════
             01  LOGIN
             ══════════════════════════════════════════════════════════════════ -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="01 Login">
          <stringProp name="HTTPSampler.path">/api/auth/login</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">{&quot;email&quot;:&quot;${email}&quot;,&quot;password&quot;:&quot;${password}&quot;}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Assert 200">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="49586">200</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">8</intProp>
          </ResponseAssertion>
          <hashTree/>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Extract Tokens">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">
def resp = prev.getResponseDataAsString()
if (!resp) return
try {
    def json = new groovy.json.JsonSlurper().parseText(resp)
    vars.put(&apos;accessToken&apos;,  json?.data?.accessToken  ?: &apos;&apos;)
    vars.put(&apos;refreshToken&apos;, json?.data?.refreshToken ?: &apos;&apos;)
} catch(e) {
    log.error(&apos;Login extract error: &apos; + e.getMessage())
}
            </stringProp>
            <stringProp name="filename"></stringProp>
          </JSR223PostProcessor>
          <hashTree/>
        </hashTree>

        <!-- Auth header for all requests below -->
        <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="Authorization Bearer">
          <collectionProp name="HeaderManager.headers">
            <elementProp name="" elementType="Header">
              <stringProp name="Header.name">Authorization</stringProp>
              <stringProp name="Header.value">Bearer ${accessToken}</stringProp>
            </elementProp>
          </collectionProp>
        </HeaderManager>
        <hashTree/>

        <!-- ══════════════════════════════════════════════════════════════════
             02  GET SUBSCRIPTION PLANS
             ══════════════════════════════════════════════════════════════════ -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="02 GET Subscription Plans">
          <stringProp name="HTTPSampler.path">/api/subscriptions/plans</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Extract Premium Plan ID">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">
def resp = prev.getResponseDataAsString()
if (!resp) return
try {
    def plans = new groovy.json.JsonSlurper().parseText(resp)?.data ?: []
    def premium = plans.find { it.name?.toLowerCase()?.contains(&apos;premium&apos;) }
    if (!premium) premium = plans.max { it.planOrder }
    vars.put(&apos;premiumPlanId&apos;, premium?.id?.toString() ?: &apos;&apos;)
} catch(e) {
    log.error(&apos;Plans extract error: &apos; + e.getMessage())
}
            </stringProp>
            <stringProp name="filename"></stringProp>
          </JSR223PostProcessor>
          <hashTree/>
        </hashTree>

        <!-- ══════════════════════════════════════════════════════════════════
             03  SUBSCRIBE TO PREMIUM
             ══════════════════════════════════════════════════════════════════ -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="03 Subscribe to Premium">
          <stringProp name="HTTPSampler.path">/api/subscriptions/subscribe</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">{&quot;planId&quot;:&quot;${premiumPlanId}&quot;}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree/>

        <!-- ══════════════════════════════════════════════════════════════════
             04  GET STATIONS
             ══════════════════════════════════════════════════════════════════ -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="04 GET Stations">
          <stringProp name="HTTPSampler.path">/api/stations?page=0&amp;size=10</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Extract Station ID">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">
def resp = prev.getResponseDataAsString()
if (!resp) return
try {
    def json = new groovy.json.JsonSlurper().parseText(resp)
    def stations = json?.data?.content ?: json?.data ?: []
    if (stations &amp;&amp; !stations.isEmpty()) {
        def idx = new Random().nextInt(stations.size())
        vars.put(&apos;stationId&apos;, stations[idx].id.toString())
    }
} catch(e) {
    log.error(&apos;Stations extract error: &apos; + e.getMessage())
}
            </stringProp>
            <stringProp name="filename"></stringProp>
          </JSR223PostProcessor>
          <hashTree/>
        </hashTree>

        <!-- ══════════════════════════════════════════════════════════════════
             05  GET CHARGERS FOR STATION
             ══════════════════════════════════════════════════════════════════ -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="05 GET Chargers">
          <stringProp name="HTTPSampler.path">/api/chargers/station/${stationId}</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Extract Charger ID">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">
def resp = prev.getResponseDataAsString()
if (!resp) return
try {
    def chargers = new groovy.json.JsonSlurper().parseText(resp)?.data ?: []
    if (chargers &amp;&amp; !chargers.isEmpty()) {
        def idx = new Random().nextInt(chargers.size())
        vars.put(&apos;chargerId&apos;, chargers[idx].id.toString())
    }
} catch(e) {
    log.error(&apos;Chargers extract error: &apos; + e.getMessage())
}
            </stringProp>
            <stringProp name="filename"></stringProp>
          </JSR223PostProcessor>
          <hashTree/>
        </hashTree>

        <!-- ══════════════════════════════════════════════════════════════════
             06  CREATE RESERVATION
             ══════════════════════════════════════════════════════════════════ -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="06 Create Reservation">
          <stringProp name="HTTPSampler.path">/api/reservations</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">{&quot;chargerId&quot;:&quot;${chargerId}&quot;,&quot;startTime&quot;:&quot;${startTime}&quot;,&quot;endTime&quot;:&quot;${endTime}&quot;}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Generate Random Time Slot">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">
import java.time.LocalDateTime
import java.time.format.DateTimeFormatter

def rnd = new Random()
int dayOffset = rnd.nextInt(30) + 1
int hour      = rnd.nextInt(12) + 8

LocalDateTime start = LocalDateTime.now()
    .plusDays(dayOffset)
    .withHour(hour).withMinute(0).withSecond(0).withNano(0)
LocalDateTime end = start.plusHours(1)

def fmt = DateTimeFormatter.ofPattern("yyyy-MM-dd'T'HH:mm:ss")
vars.put(&apos;startTime&apos;, start.format(fmt))
vars.put(&apos;endTime&apos;,   end.format(fmt))
            </stringProp>
            <stringProp name="filename"></stringProp>
          </JSR223PreProcessor>
          <hashTree/>
        </hashTree>

        <!-- ══════════════════════════════════════════════════════════════════
             07  VIEW MY RESERVATIONS
             ══════════════════════════════════════════════════════════════════ -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="07 GET My Reservations">
          <stringProp name="HTTPSampler.path">/api/reservations/my?page=0&amp;size=5</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree/>

        <!-- ══════════════════════════════════════════════════════════════════
             LISTENERS
